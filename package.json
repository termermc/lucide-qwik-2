{
	"name": "lucide-qwik-2",
	"version": "0.0.0",
	"description": "Lucide icon library package for Qwik applications",
	"author": {
		"name": "termer",
		"email": "termer@termer.net",
		"url": "https://github.com/termermc"
	},
	"repository": {
		"type": "git",
		"url": "git+https://github.com/termermc/lucide-qwik-2.git"
	},
	"license": "LICENSE",
	"keywords": [
		"icon",
		"icons",
		"lucide",
		"qwik"
	],
	"main": "./lib/index.js",
	"qwik": "./lib/index.js",
	"sideEffects": false,
	"types": "./lib-types/index.d.ts",
	"exports": {
		".": {
			"types": "./lib-types/index.d.ts",
			"import": "./lib/index.js"
		}
	},
	"files": [
		"lib",
		"lib-types"
	],
	"engines": {
		"node": ">=20.0.0"
	},
	"private": false,
	"type": "module",
	"scripts": {
		"codegen": "node ./script/build-icons.ts",
		"build": "node script/build-all.ts",
		"build.lib": "vite build --mode lib",
		"build.types": "tsc --emitDeclarationOnly",
		"dev": "vite --mode ssr",
		"dev.debug": "node --inspect-brk ./node_modules/vite/bin/vite.js --mode ssr --force",
		"fmt": "prettier --write .",
		"fmt.check": "prettier --check .",
		"lint": "eslint \"src/**/*.ts*\"",
		"release": "rm -rf lib* && npm run build && np",
		"start": "vite --open --mode ssr",
		"qwik": "qwik",
		"test": "echo no tests for now"
	},
	"devDependencies": {
		"@eslint/js": "^9",
		"@qwik.dev/core": "2.0.0-beta.37",
		"@types/node": "^26.1.0",
		"eslint": "9.32.0",
		"eslint-plugin-qwik": "2.0.0-beta.37",
		"lucide": "^1.23.0",
		"np": "^11.2.1",
		"prettier": "^3.9.4",
		"typescript": "6.0.3",
		"typescript-eslint": "^8.62.1",
		"undici": "*",
		"vite": "8.0.5",
		"vite-tsconfig-paths": "^4.2.1"
	}
}
