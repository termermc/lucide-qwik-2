{
	"compilerOptions": {
		"allowJs": true,
		"target": "ES2017",
		"module": "esnext",
		"lib": ["esnext", "DOM"],
		"jsx": "react-jsx",
		"jsxImportSource": "@qwik.dev/core",
		"strict": true,
		"declaration": true,
		"declarationDir": "lib-types",
		"resolveJsonModule": true,
		"moduleResolution": "bundler",
		"esModuleInterop": true,
		"skipLibCheck": true,
		"incremental": true,
		"isolatedModules": true,
		"allowImportingTsExtensions": true,
		"checkJs": true,
		"types": ["vite/client"]
	},
	"include": ["src", "build.ts", "eslint.config.js"]
}
